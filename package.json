{
  "name": "nexus-discord-bot",
  "version": "1.0.0",
  "description": "Nexus Discord Bot",
  "author": "Delemangi",
  "license": "MIT",
  "homepage": "https://github.com/Delemangi/nexus-discord-bot",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Delemangi/nexus-discord-bot.git"
  },
  "bugs": {
    "url": "https://github.com/Delemangi/nexus-discord-bot/issues"
  },
  "main": "src/index.ts",
  "type": "module",
  "engines": {
    "node": "^24"
  },
  "scripts": {
    "build": "npm run clean && node esbuild.config.js && tsc-alias",
    "check": "tsc --noEmit",
    "clean": "rimraf dist",
    "dev": "tsx src/index.ts",
    "format": "eslint . --cache --fix",
    "lint": "eslint . --cache",
    "start": "node dist/index.js",
    "start:env": "node --env-file=.env dist/index.js"
  },
  "dependencies": {
    "@sapphire/framework": "^5.5.0",
    "@sapphire/plugin-subcommands": "^7.0.1",
    "@sapphire/utilities": "^3.18.2",
    "better-sqlite3": "^12.9.0",
    "chrono-node": "^2.9.0",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-imperium": "^3.6.0",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
